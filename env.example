# ── Copy this file to .env and fill in your keys ──────────────────────────────
# Only fill in the key for the provider you're using.
# Change ACTIVE_PROVIDER in src/config/ai.js to switch providers.

# Google Gemini — FREE tier (recommended to start)
# Get key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_key_here

# Mistral — FREE tier available
# Get key: https://console.mistral.ai
VITE_MISTRAL_API_KEY=your_mistral_key_here

# OpenRouter — FREE models available (Llama, Mistral, etc.)
# Get key: https://openrouter.ai
VITE_OPENROUTER_API_KEY=your_openrouter_key_here

# OpenAI — Paid
# Get key: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_key_here

# Anthropic Claude — Paid
# Get key: https://console.anthropic.com
VITE_CLAUDE_API_KEY=your_claude_key_here

# Mapbox — FREE tier: 50,000 map loads/month
# Get token: https://account.mapbox.com → Tokens → Create a token
VITE_MAPBOX_TOKEN=your_mapbox_token_here
